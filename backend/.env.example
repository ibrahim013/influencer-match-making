# OpenAI (GPT-4o + embeddings + moderation)
OPENAI_API_KEY=sk-...

# Pinecone (langchain-pinecone + Pinecone Inference embeddings)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=influencer-creators
# Pinecone Inference model (default: llama-text-embed-v2, 1024-d — align index with Pinecone docs)
PINECONE_EMBEDDING_MODEL=llama-text-embed-v2
# Optional for legacy indexes; serverless often omits this
PINECONE_ENVIRONMENT=

# Postgres checkpointer (docker-compose default)
DATABASE_URL=postgresql://langgraph:langgraph@localhost:5432/langgraph

# Outbound brand integrity — comma-separated competitor names
COMPETITOR_LIST=Nike,Adidas,Puma,Reebok

# Optional tuning
OPENAI_CHAT_MODEL=gpt-4o

# Guardrails: synchronous validator pipeline (default true; avoids no-event-loop
# warnings when guard runs off the asyncio thread). Set to false if you rely on
# async validators on the main thread only.
# GUARDRAILS_RUN_SYNC=true

# Comma-separated origins for FastAPI CORS (Vite default included if unset)
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Logging: text (default) or json for structured log drains
# LOG_FORMAT=json

# LangSmith — set LANGSMITH_TRACING=true and LANGSMITH_API_KEY to trace graph + LLM runs
# LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=matchmaking
# LANGSMITH_WORKSPACE_ID=
